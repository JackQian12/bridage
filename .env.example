# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgres://bridage:bridage@localhost:5432/bridage?sslmode=disable

# 32+ character master key used to encrypt provider API keys at rest (AES-256-GCM)
MASTER_KEY=change-me-this-must-be-at-least-32-chars

# JWT signing secret for admin sessions
JWT_SECRET=change-me-jwt-secret

# ── Optional ──────────────────────────────────────────────────────────────────

# Address the HTTP server listens on (default: 0.0.0.0:8080)
LISTEN_ADDR=0.0.0.0:8080

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# Comma-separated CORS origins, or * for all (default: *)
CORS_ORIGINS=*

# JWT expiry duration (default: 24h)
JWT_EXPIRY=24h

# Upstream provider request timeout (default: 120s)
PROVIDER_TIMEOUT=120s

# Upstream provider retry count on transient errors (default: 2)
PROVIDER_RETRIES=2

# If set, an admin user with this username (and this value as the initial password)
# is auto-created on first boot. Change the password immediately after first login.
# ADMIN_BOOTSTRAP_TOKEN=admin
